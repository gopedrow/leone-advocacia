# ───────────────────────────────────────────────────────────
# Banco de dados
# Dev: SQLite (padrão). Produção: troque para PostgreSQL.
# ───────────────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"
# Exemplo PostgreSQL:
# DATABASE_URL="postgresql://user:senha@localhost:5432/leone?schema=public"

# ───────────────────────────────────────────────────────────
# Autenticação (JWT)
# Gere uma chave forte: openssl rand -base64 48
# ───────────────────────────────────────────────────────────
JWT_SECRET="troque-por-uma-chave-secreta-bem-longa-e-aleatoria"
JWT_ISSUER="leone-advocacia"
SESSION_MAX_AGE_DAYS=7

# ───────────────────────────────────────────────────────────
# Site
# ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_WHATSAPP="55XXXXXXXXXXX"

# ───────────────────────────────────────────────────────────
# Meta (Facebook/Instagram) — Lead Ads + Conversions API
# Preencha no Vercel quando o app do Meta estiver aprovado.
# ───────────────────────────────────────────────────────────
# Webhook de Lead Ads (recebe leads dos anúncios):
META_VERIFY_TOKEN=""        # texto que você define e repete no painel do Meta
META_APP_SECRET=""          # "App Secret" do app do Meta (valida a assinatura)
META_PAGE_ACCESS_TOKEN=""   # token da Página com permissão leads_retrieval
# Conversions API (envia conversões ao Meta):
META_PIXEL_ID=""            # ID do conjunto de dados / pixel
META_CAPI_TOKEN=""          # token de acesso da Conversions API
# META_TEST_EVENT_CODE=""   # opcional, para testar em "Test Events"
META_GRAPH_VERSION="v21.0"  # opcional

# ───────────────────────────────────────────────────────────
# Integrações futuras com tribunais (placeholders)
# ───────────────────────────────────────────────────────────
PJE_API_BASE_URL=""
PJE_API_TOKEN=""
ESAJ_API_BASE_URL=""
PROJUDI_API_BASE_URL=""
EPROC_API_BASE_URL=""
